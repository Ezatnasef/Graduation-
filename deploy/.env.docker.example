# Copy this file to .env before docker compose up if needed.
# Frontend public port on the server host
SERVIA_PUBLIC_PORT=80

# Backend LLM/Ollama config
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q8_0
OLLAMA_MAX_TOKENS=110
OLLAMA_GENERATE_TIMEOUT_SECONDS=18

# TTS/STT defaults for server-safe deployment
TTS_PROVIDER=edge
STT_PROVIDER=whisper_api
STT_WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions

# Optional cloud keys
STT_WHISPER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional local-model mode (uncomment and mount folders in compose if you need them)
# TTS_PROVIDER=xtts
# STT_PROVIDER=egyptalk
# XTTS_MODEL_DIR=/app/NileTTS-XTTS
# STT_EGYPTALK_LOCAL_MODEL=/app/EgypTalk-ASR-v2
