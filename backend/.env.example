# =========================
# Servia runtime config
# =========================

# LLM
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q8_0
OLLAMA_MAX_TOKENS=110
OLLAMA_GENERATE_TIMEOUT_SECONDS=18
OLLAMA_MAX_RETRIES=1
OLLAMA_SYSTEM_PROMPT_LANG=arabic

# TTS (Egyptian local voice by default)
TTS_PROVIDER=xtts
TTS_DUAL_QUALITY_ORDER=chatterbox,xtts
TTS_AUTO_LOCAL_ORDER=chatterbox,xtts
TTS_SEGMENT_MAX_CHARS=140
XTTS_TIMEOUT_SECONDS=60
XTTS_FAILURE_COOLDOWN_SECONDS=45
CHATTERBOX_FAILURE_COOLDOWN_SECONDS=45
TTS_WARMUP_TIMEOUT_SECONDS=180
CHATTERBOX_TIMEOUT_SECONDS=14
CHATTERBOX_MODEL_DIR=
CHATTERBOX_LANGUAGE=ar
CHATTERBOX_ALLOW_REMOTE=0
CHATTERBOX_USE_MULTILINGUAL=1
TTS_HUMAN_STYLE_ENABLED=0
XTTS_REFERENCE_AUDIO=
XTTS_REFERENCE_AUDIO_FEMALE=
XTTS_REFERENCE_AUDIO_MALE=

# STT provider mode: auto | egyptalk | whisper_api | faster_whisper | browser
# auto = latency-first (faster-whisper -> whisper_api -> browser) and optional EgypTalk
STT_PROVIDER=auto
STT_WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
STT_WHISPER_API_KEY=
STT_WHISPER_MODEL=gpt-4o-mini-transcribe
STT_AUTO_USE_EGYPTALK=0

# EgypTalk (NeMo) config
# Option A: keep empty and load from Hugging Face model id
# Option B: set STT_EGYPTALK_LOCAL_MODEL to a local .nemo file or directory containing .nemo
STT_EGYPTALK_MODEL_ID=NAMAA-Space/EgypTalk-ASR-v2
STT_EGYPTALK_LOCAL_MODEL=
STT_EGYPTALK_TIMEOUT_SECONDS=10

STT_FASTER_WHISPER_MODEL=small
STT_FASTER_WHISPER_DEVICE=auto
STT_FASTER_WHISPER_COMPUTE_TYPE=int8

STT_MAX_LATENCY_MS=7000
STT_MIN_CONFIDENCE=0.35
STT_WHISPER_TIMEOUT_SECONDS=12
STT_LOCAL_TIMEOUT_SECONDS=8

# Memory summarization
MEMORY_MAX_RECENT_MESSAGES=12
MEMORY_SUMMARIZE_AFTER_MESSAGES=16
MEMORY_SUMMARIZE_AFTER_TOKENS=900
