# Hugging Face gated dataset integration
# 1) Accept dataset terms at:
#    https://huggingface.co/datasets/raniahossam/egypt_dialect
# 2) Create a token on Hugging Face and set it here

HF_TOKEN=hf_your_token_here
HF_DATASET_ID=raniahossam/egypt_dialect
HF_CONFIG=default

# Optional: pick one split or leave empty to import all splits
HF_SPLIT=train
HF_OFFSET=0

# Output consumed by runtime context retriever
CODESWITCH_OUTPUT_PATH=backend/codeswitch_dataset_samples.txt
# Start with smaller batches to avoid 429, then increase gradually.
CODESWITCH_MAX_LINES=1000
CODESWITCH_OVERWRITE=true
CODESWITCH_ALLOW_FALLBACK=false

# Runtime retriever input path (used by dialect_mapper.py)
CODESWITCH_DATASET_PATH=backend/codeswitch_dataset_samples.txt
